{
  "name": "parser-source-catalog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:data": "python3 scripts/build_catalog.py",
    "generate:sqlite": "python3 scripts/build_catalog_db.py --input public/data/sources.json --output public/data/sources.sqlite",
    "generate:all": "npm run generate:data && npm run generate:sqlite",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/compiler-sfc": "^3.5.22",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
